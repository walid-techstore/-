            {label:"العقود النشطة",value:contracts.filter(c=>c.status==="نشط").length,color:"#1D9E75",icon:"✅"},
            {label:"المتأخرة",value:contracts.filter(c=>c.status==="متأخر").length,color:"#E24B4A",icon:"⚠️"},
            {label:"المكتملة",value:contracts.filter(c=>c.status==="مكتمل").length,color:"#185FA5",icon:"🏁"},
            {label:"إجمالي الأرباح",value:stats.profit.toLocaleString()+" دج",color:"#FFC800",icon:"📈"},
            {label:"الديون المتبقية",value:stats.debt.toLocaleString()+" دج",color:"#E24B4A",icon:"📉"},
          ].map((s,i)=>
            React.createElement("div",{key:i,className:"sc",style:{background:"#1A1A1A",border:"1px solid #222",borderRadius:14,padding:"16px 18px"}},
              React.createElement("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:10}},
                React.createElement("span",{style:{fontSize:12,color:"#666"}},s.label),
                React.createElement("span",{style:{fontSize:20}},s.icon)
              ),
              React.createElement("div",{style:{fontSize:20,fontWeight:900,color:s.color}},s.value)
            )
          )
        ),
        React.createElement("div",{style:{background:"#1A1A1A",border:"1px solid #222",borderRadius:14,padding:"18px 22px"}},
          React.createElement("h3",{style:{fontSize:15,fontWeight:700,margin:"0 0 16px"}},"تفاصيل جميع العقود"),
          React.createElement("table",{style:{width:"100%",borderCollapse:"collapse",fontSize:12}},
            React.createElement("thead",null,
              React.createElement("tr",{style:{background:"#161616",color:"#555"}},
                ["الزبون","المنتج","السعر","القسط","المدفوع","المتبقي","الحالة","البداية"].map(h=>
                  React.createElement("th",{key:h,style:{padding:"10px 12px",fontWeight:600,textAlign:"right",borderBottom:"1px solid #222"}},h)
                )
              )
            ),
            React.createElement("tbody",null,
              contracts.map(c=>{
                const monthly=calcMonthly(c.price,c.downPayment,c.months);
                const rem=c.months-(c.paidMonths||0);
                const sc=SC[c.status];
                return React.createElement("tr",{key:c.id,style:{borderBottom:"1px solid #1E1E1E"}},
                  React.createElement("td",{style:{padding:"10px 12px",fontWeight:600}},c.client),
                  React.createElement("td",{style:{color:"#888"}},c.product),
                  React.createElement("td",{style:{color:"#FFC800",fontWeight:700}},c.price.toLocaleString()+" دج"),
                  React.createElement("td",{style:{color:"#888"}},monthly.toLocaleString()+" دج"),
                  React.createElement("td",{style:{color:"#1D9E75"}},(c.paidMonths||0)+" / "+c.months),
                  React.createElement("td",{style:{color:rem>0?"#E24B4A":"#1D9E75"}},rem>0?rem+" شهر":"✓ مكتمل"),
                  React.createElement("td",null,React.createElement("span",{style:{background:sc.bg,color:sc.color,padding:"2px 8px",borderRadius:12,fontSize:11}},c.status)),
                  React.createElement("td",{style:{color:"#666",fontSize:11}},formatDate(c.startDate||c.date))
                );
              }),
              contracts.length===0&&React.createElement("tr",null,React.createElement("td",{colSpan:8,style:{padding:32,textAlign:"center",color:"#444"}},"لا توجد عقود"))
            )
          )
        )
      )

    ) // end main
  ); // end return
} // end AldarApp

const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(React.createElement(AldarApp));
</script>
</body>
