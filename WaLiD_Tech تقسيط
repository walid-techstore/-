<body>
<div id="root"></div>
<script>
const {useState,useMemo,useEffect} = React;

const MONTHS_LIST = [3,4,6,9,12,18,24];

const SC = {
  "نشط":{bg:"rgba(29,158,117,0.15)",color:"#1D9E75"},
  "متأخر":{bg:"rgba(226,75,74,0.15)",color:"#E24B4A"},
  "مكتمل":{bg:"rgba(55,138,221,0.15)",color:"#185FA5"},
};

const INIT = [
  {id:1,client:"محمد علي",phone:"0550123456",ccp:"12345678/12",product:"iPhone 15",costPrice:120000,price:180000,downPayment:0,months:12,status:"نشط",date:"2025-01-15",paidMonths:3,startDate:"2025-01-15",installmentDates:[]},
  {id:2,client:"أحمد كريم",phone:"0661234567",ccp:"87654321/05",product:'TV Samsung 65"',costPrice:150000,price:220000,downPayment:20000,months:6,status:"متأخر",date:"2025-02-20",paidMonths:1,startDate:"2025-02-20",installmentDates:[]},
  {id:3,client:"فاطمة بن علي",phone:"0770987654",ccp:"11223344/08",product:"MacBook Air",costPrice:220000,price:310000,downPayment:30000,months:18,status:"نشط",date:"2025-03-05",paidMonths:5,startDate:"2025-03-05",installmentDates:[]},
];

function calcMonthly(price,downPayment,months){
  return Math.round(price/months);
}
function calcProfit(price,costPrice,downPayment){
  return (price||0)-(costPrice||0);
}
function addMonths(dateStr,n){
  if(!dateStr) return "";
  const d=new Date(dateStr);
  d.setMonth(d.getMonth()+n);
  return d.toISOString().split("T")[0];
}
function formatDate(d){
  if(!d) return "—";
  return d.split("-").reverse().join("/");
}
function getInstallmentDates(startDate,months){
  const dates=[];
  for(let i=1;i<=months;i++) dates.push(addMonths(startDate,i));
  return dates;
}

function AldarApp(){
  const [page,setPage]=useState("dashboard");
  const [contracts,setContracts]=useState(()=>{
    try{
      const s=localStorage.getItem("aldar_v2");
      const data=s?JSON.parse(s):INIT;
      const today=new Date();
      const todayStr=today.toISOString().split("T")[0];
      // يوم 02 من كل شهر — ننح قسط واحد فقط
      const day=today.getDate();
      const thisMonth=todayStr.substring(0,7); // YYYY-MM
      const lastRun=localStorage.getItem("aldar_lastrun")||"";
      if(day>=2 && thisMonth!==lastRun){
        let changed=false;
        const updated=data.map(c=>{
          if(c.status==="مكتمل") return c;
          const paid=(c.paidMonths||0)+1;
          if(paid>c.months) return c;
          changed=true;
          return{...c,paidMonths:paid,status:paid>=c.months?"مكتمل":c.status==="متأخر"?"نشط":c.status};
        });
        localStorage.setItem("aldar_lastrun",thisMonth);
        if(changed){
          localStorage.setItem("aldar_v2",JSON.stringify(updated));
          return updated;
        }
      }
      return data;
    }catch(e){return INIT;}
  });
  const [search,setSearch]=useState("");
  const [filterStatus,setFilterStatus]=useState("الكل");
  const [filterMonth,setFilterMonth]=useState("");
  const [selected,setSelected]=useState(null);
  const [saved,setSaved]=useState(false);
  const getDay2 = () => { const d=new Date(); d.setMonth(d.getMonth()+1); d.setDate(2); return d.toISOString().split("T")[0]; };
  const [aiLoading,setAiLoading]=useState(false);
  const [suppliers,setSuppliers]=useState(()=>{
    try{const s=localStorage.getItem("aldar_suppliers");return s?JSON.parse(s):[];}catch(e){return [];}
  });
  const [supForm,setSupForm]=useState({name:"",phone:""});
  const [supSearch,setSupSearch]=useState("");
  const [selSup,setSelSup]=useState(null);
  const [supTab,setSupTab]=useState("account");
  const [supShowAll,setSupShowAll]=useState(false);
  const [goodForm,setGoodForm]=useState({name:"",qty:"",price:"",date:new Date().toISOString().split("T")[0]});
  const [payForm,setPayForm]=useState({amount:"",date:new Date().toISOString().split("T")[0]});
  const [debtForm,setDebtForm]=useState({amount:"",note:"",date:new Date().toISOString().split("T")[0]});
  const [form,setForm]=useState({client:"",phone:"",ccp:"",product:"",costPrice:"",price:"",downPayment:"",months:12,startDate:getDay2(),pdfFile:"",pdfUrl:"",supplierId:""});
  // إذا عند المستخدم مورد واحد فقط، اربط العقد الجديد به تلقائياً
  useEffect(()=>{
    if(page==="new"&&!form.supplierId&&suppliers.length===1){
      setForm(f=>f.supplierId?f:{...f,supplierId:String(suppliers[0].id)});
    }
  },[page,suppliers.length]);
  const [detailTab,setDetailTab]=useState("info");
  const [editMode,setEditMode]=useState(false);
  const [editForm,setEditForm]=useState(null);
  const [calcIds,setCalcIds]=useState([]);
  const [calcSearch,setCalcSearch]=useState("");
  const [sortField,setSortField]=useState("");
  const [sortDir,setSortDir]=useState(1);
  const [calcMonth,setCalcMonth]=useState("");
  const [calcSepDate,setCalcSepDate]=useState("");
  const [calcSup,setCalcSup]=useState("");
  const [editCostId,setEditCostId]=useState(null);
  const [editCostVal,setEditCostVal]=useState("");
  const [supContractDate,setSupContractDate]=useState("");
  const [editGoodId,setEditGoodId]=useState(null);
  const [editGoodForm,setEditGoodForm]=useState(null);
  const [shopName,setShopName]=useState(()=>localStorage.getItem('aldar_shop')||'الدّار للتقسيط');

  function saveS(arr){
    setSuppliers(arr);
    try{localStorage.setItem("aldar_suppliers",JSON.stringify(arr));}catch(e){}
  }
  function addSupplier(){
    if(!supForm.name) return;
    saveS([{id:Date.now(),name:supForm.name,phone:supForm.phone,goods:[],payments:[],debts:[],archive:[],files:[]}, ...suppliers]);
    setSupForm({name:"",phone:""});
  }
  function linkContractToSupplier(contractId, supId){
    const updated = contracts.map(c=>c.id===contractId?{...c,supplierId:String(supId)}:c);
    saveC(updated);
  }
  function unlinkContractFromSupplier(contractId){
    const updated = contracts.map(c=>c.id===contractId?{...c,supplierId:""}:c);
    saveC(updated);
  }

  function addSeparator(supId){
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,goods:[...s.goods,{id:Date.now(),isSeparator:true,date:new Date().toISOString().split("T")[0],name:"--- بداية حساب جديد ---",price:0,qty:0}]}));
  }
  function addGood(supId, type){
    if(!goodForm.name||!goodForm.price) return;
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,goods:[...s.goods,{id:Date.now(),name:goodForm.name,qty:parseFloat(goodForm.qty)||1,price:parseFloat(goodForm.price),date:goodForm.date,type:type||"taken"}]}));
    setGoodForm({name:"",qty:"",price:"",date:new Date().toISOString().split("T")[0]});
    setSelSup(suppliers.find(s=>s.id===supId));
  }
  function startEditGood(g){
    setEditGoodId(g.id);
    setEditGoodForm({name:g.name,qty:g.qty||1,price:g.price,date:g.date});
  }
  function cancelEditGood(){
    setEditGoodId(null);
    setEditGoodForm(null);
  }
  function saveEditGood(supId){
    if(!editGoodForm) return;
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,goods:s.goods.map(g=>g.id===editGoodId?{...g,name:editGoodForm.name,qty:parseFloat(editGoodForm.qty)||1,price:parseFloat(editGoodForm.price)||0,date:editGoodForm.date}:g)}));
    setSelSup(suppliers.find(s=>s.id===supId));
    setEditGoodId(null);
    setEditGoodForm(null);
  }
  function deleteGoodItem(supId, goodId){
    if(!window.confirm("متأكد من حذف هذه السلعة؟ لا يمكن التراجع.")) return;
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,goods:s.goods.filter(g=>g.id!==goodId)}));
    setSelSup(suppliers.find(s=>s.id===supId));
  }
  function addDebt(supId, type){
    if(!debtForm.amount) return;
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,debts:[...(s.debts||[]),{id:Date.now(),amount:parseFloat(debtForm.amount),note:debtForm.note,date:debtForm.date,type:type||"علي"}]}));
    setDebtForm({amount:"",note:"",date:new Date().toISOString().split("T")[0]});
    setSelSup(suppliers.find(s=>s.id===supId));
  }
  function deleteDebtItem(supId, debtId){
    if(!window.confirm("متأكد من حذف هذا الدين؟ لا يمكن التراجع.")) return;
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,debts:(s.debts||[]).filter(d=>d.id!==debtId)}));
    setSelSup(suppliers.find(s=>s.id===supId));
  }
  function deletePaymentItem(supId, payId){
    if(!window.confirm("متأكد من حذف هذه الدفعة؟ لا يمكن التراجع.")) return;
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,payments:s.payments.filter(p=>p.id!==payId)}));
    setSelSup(suppliers.find(s=>s.id===supId));
  }
  function addPayment(supId, type){
    if(!payForm.amount) return;
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,payments:[...s.payments,{id:Date.now(),amount:parseFloat(payForm.amount),date:payForm.date,type:type||"عليه"}]}));
    setPayForm({amount:"",date:new Date().toISOString().split("T")[0]});
    setSelSup(suppliers.find(s=>s.id===supId));
  }
  function clearAccount(supId){
    if(!window.confirm("تصفية الحساب؟ سيتم أرشفة الحساب الحالي وبدء حساب جديد.")) return;
    saveS(suppliers.map(s=>{
      if(s.id!==supId) return s;
      const entry={date:new Date().toISOString().split("T")[0],goods:s.goods,payments:s.payments,debts:s.debts||[],balance:calcBalance(s)};
      return {...s,goods:[],payments:[],debts:[],archive:[...s.archive,entry]};
    }));
    setSelSup(null);
  }
  function getNewItems(s){
    // Find last separator index
    let lastSep=-1;
    s.goods.forEach((g,i)=>{ if(g.isSeparator) lastSep=i; });
    const newGoods=lastSep>=0?s.goods.slice(lastSep+1):s.goods;
    // For payments/debts: count entries after separator date
    let newPayments=s.payments;
    let newDebts=s.debts||[];
    if(lastSep>=0){
      const sepDate=s.goods[lastSep].date;
      newPayments=s.payments.filter(p=>p.date>=sepDate);
      newDebts=(s.debts||[]).filter(d=>d.date>=sepDate);
    }
    return{newGoods,newPayments,newDebts};
  }
  function calcBalance(s,newOnly=true){
    // ما عليك = سلع مأخوذة + دين عليّ - دفعات (علي)
    // ما عليه = عقود + سلع مسلّمة قديمة + دين عليه + دفعات (عليه)
    const linkedCost=contracts.filter(c=>c.supplierId===String(s.id)).reduce((t,c)=>t+(c.costPrice||0),0);
    const goods=newOnly?getNewItems(s).newGoods:s.goods;
    const pays=newOnly?getNewItems(s).newPayments:s.payments;
    const debts=newOnly?getNewItems(s).newDebts:(s.debts||[]);
    const taken=goods.filter(g=>!g.isSeparator&&g.type!=="delivered").reduce((t,g)=>t+g.price*(g.qty||1),0);
    const legacyDelivered=goods.filter(g=>!g.isSeparator&&g.type==="delivered").reduce((t,g)=>t+g.price*(g.qty||1),0);
    const paidByMe=pays.filter(p=>p.type==="علي").reduce((t,p)=>t+p.amount,0);
    const paidByHim=pays.filter(p=>p.type!=="علي").reduce((t,p)=>t+p.amount,0);
    const debtOnMe=debts.filter(d=>d.type==="عليّ"||d.type==="علي").reduce((t,d)=>t+d.amount,0);
    const debtOnHim=debts.filter(d=>d.type==="عليه").reduce((t,d)=>t+d.amount,0);
    return (taken+debtOnMe-paidByMe)-(linkedCost+legacyDelivered+debtOnHim+paidByHim);
  }
  function calcBalanceParts(s,newOnly=true){
    const linkedCost=contracts.filter(c=>c.supplierId===String(s.id)).reduce((t,c)=>t+(c.costPrice||0),0);
    const goods=newOnly?getNewItems(s).newGoods:s.goods;
    const pays=newOnly?getNewItems(s).newPayments:s.payments;
    const debts=newOnly?getNewItems(s).newDebts:(s.debts||[]);
    const taken=goods.filter(g=>!g.isSeparator&&g.type!=="delivered").reduce((t,g)=>t+g.price*(g.qty||1),0);
    const legacyDelivered=goods.filter(g=>!g.isSeparator&&g.type==="delivered").reduce((t,g)=>t+g.price*(g.qty||1),0);
    const paidByMe=pays.filter(p=>p.type==="علي").reduce((t,p)=>t+p.amount,0);
    const paidByHim=pays.filter(p=>p.type!=="علي").reduce((t,p)=>t+p.amount,0);
    const debtOnMe=debts.filter(d=>d.type==="عليّ"||d.type==="علي").reduce((t,d)=>t+d.amount,0);
    const debtOnHim=debts.filter(d=>d.type==="عليه").reduce((t,d)=>t+d.amount,0);
    const delivered=linkedCost+legacyDelivered;
    const totalPaid=paidByMe+paidByHim;
    return{taken,delivered,linkedCost,legacyDelivered,paidByMe,paidByHim,totalPaid,debtOnMe,debtOnHim,balance:(taken+debtOnMe-paidByMe)-(delivered+debtOnHim+paidByHim)};
  }
  function addSupFile(supId, file){
    const url = URL.createObjectURL(file);
    saveS(suppliers.map(s=>s.id!==supId?s:{
      ...s,
      files:[...(s.files||[]),{id:Date.now(),name:file.name,url,date:new Date().toISOString().split("T")[0]}]
    }));
  }
  function removeSupFile(supId, fileId){
    saveS(suppliers.map(s=>s.id!==supId?s:{...s,files:(s.files||[]).filter(f=>f.id!==fileId)}));
  }
  function printSupplier(s){
    const balance=calcBalance(s);
    const goodsRows=s.goods.filter(g=>!g.isSeparator).map(g=>g.type==="delivered"
      ?`<tr><td>${g.date}</td><td>📤 ${g.name} (مسلّم)</td><td>${g.qty||1}</td><td>${g.price.toLocaleString()} دج</td><td style="color:green">- ${(g.price*(g.qty||1)).toLocaleString()} دج</td></tr>`
      :`<tr><td>${g.date}</td><td>📥 ${g.name} (مأخوذ)</td><td>${g.qty||1}</td><td>${g.price.toLocaleString()} دج</td><td>${(g.price*(g.qty||1)).toLocaleString()} دج</td></tr>`
    ).join("");
    const payRows=s.payments.map(p=>p.type==="علي"
      ?`<tr><td>${p.date}</td><td colspan="3">💸 دفعة عليّ (دفعتها للمورد)</td><td style="color:red">- ${p.amount.toLocaleString()} دج</td></tr>`
      :`<tr><td>${p.date}</td><td colspan="3">💰 دفعة عليه (دفعها المورد لي)</td><td style="color:green">- ${p.amount.toLocaleString()} دج</td></tr>`
    ).join("");
    const win=window.open("","_blank");
    win.document.write(`<!DOCTYPE html><html dir="rtl"><head><meta charset="UTF-8"><style>body{font-family:Arial;padding:20px;direction:rtl}h1{color:#b8860b}table{width:100%;border-collapse:collapse;font-size:13px}th{background:#b8860b;color:#fff;padding:8px;text-align:right}td{border:1px solid #ddd;padding:7px}.balance{font-size:20px;font-weight:bold;color:${balance>0?"red":"green"}}@media print{button{display:none}}</style></head><body>
    <h1>${shopName} — كشف حساب مورد</h1>
    <p><b>المورد:</b> ${s.name} &nbsp; <b>الهاتف:</b> ${s.phone||"—"}</p>
    <table><thead><tr><th>التاريخ</th><th>السلعة</th><th>الكمية</th><th>السعر</th><th>المجموع</th></tr></thead>
    <tbody>${goodsRows}${payRows}</tbody></table>
    <br/><p class="balance">الرصيد الحالي: ${balance.toLocaleString()} دج</p>
    <button onclick="window.print()" style="background:#b8860b;color:#fff;border:none;padding:10px 24px;font-size:14px;border-radius:6px;cursor:pointer;margin-top:10px">🖨 طباعة</button>
    </body></html>`);
    win.document.close();
  }

  function handleSort(field){
    if(sortField===field) setSortDir(d=>-d);
    else{ setSortField(field); setSortDir(1); }
  }
  function sortIcon(field){ return sortField===field?(sortDir===1?" ▲":" ▼"):" ·"; }

  function checkCompletedContracts(data){
    const today=new Date();
    const thisMonth=today.toISOString().substring(0,7);
    const completed=data.filter(c=>{
      if(c.status!=="مكتمل") return false;
      const dates=c.installmentDates&&c.installmentDates.length?c.installmentDates:getInstallmentDates(c.startDate||c.date,c.months);
      const lastDate=dates[c.months-1]||"";
      return lastDate.startsWith(thisMonth);
    });
    if(completed.length>0){
      const lastShown=localStorage.getItem("aldar_notify_month")||"";
      if(lastShown!==thisMonth){
        setTimeout(()=>{
          alert("🎉 تهانينا!\nانتهت هذه العقود هذا الشهر:\n"+completed.map(c=>"• "+c.client+" ("+c.product+")").join("\n"));
          localStorage.setItem("aldar_notify_month",thisMonth);
        },1000);
      }
    }
  }

    const saveC=(arr)=>{
    setContracts(arr);
    try{localStorage.setItem("aldar_v2",JSON.stringify(arr));}catch(e){}
  };

  // Stats
  const stats=useMemo(()=>{
    const active=contracts.filter(c=>c.status!=="مكتمل");
    const totalDebt=active.reduce((s,c)=>s+(calcMonthly(c.price,c.downPayment,c.months)*(c.months-(c.paidMonths||0))),0);
    const totalProfit=contracts.reduce((s,c)=>s+calcProfit(c.price,c.costPrice,c.downPayment),0);
    const collected=contracts.reduce((s,c)=>s+(calcMonthly(c.price,c.downPayment,c.months)*(c.paidMonths||0))+(c.downPayment||0),0);
    const late=contracts.filter(c=>c.status==="متأخر").length;
    return{clients:[...new Set(contracts.map(c=>c.client))].length,total:contracts.length,debt:totalDebt,profit:totalProfit,collected,late};
  },[contracts]);

  const filtered=useMemo(()=>contracts.filter(c=>{
    const ms=c.client.includes(search)||c.product.includes(search)||(c.phone||"").includes(search)||(c.ccp||"").includes(search);
    const ss=filterStatus==="الكل"||c.status===filterStatus;
    const mDate=!filterMonth||(c.startDate||c.date||"").startsWith(filterMonth);
    return ms&&ss&&mDate;
  }).sort((a,b)=>{
    if(!sortField) return 0;
    let va=a[sortField]||"", vb=b[sortField]||"";
    if(sortField==="price"||sortField==="costPrice"||sortField==="paidMonths"||sortField==="months"){va=Number(va);vb=Number(vb);}
    if(va<vb) return -sortDir;
    if(va>vb) return sortDir;
    return 0;
  }),[contracts,search,filterStatus,filterMonth,sortField,sortDir]);

  const preview=useMemo(()=>{
    const p=parseFloat(form.price)||0;
    const cp=parseFloat(form.costPrice)||0;
    const dp=parseFloat(form.downPayment)||0;
    if(p>0){
      const monthly=calcMonthly(p,dp,form.months);
      const profit=p-cp;
      const endDate=addMonths(form.startDate,form.months);
      return{monthly,profit,total:p,endDate};
    }
    return null;
  },[form]);

  async function analyzeArchive(file){
    setAiLoading(true);
    try{
      let extractedText = "";

      if(file.type === "application/pdf"){
        const pdfjsLib = window["pdfjs-dist/build/pdf"];
        pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.worker.min.js";
        const arrayBuffer = await file.arrayBuffer();
        const pdf = await pdfjsLib.getDocument({data: arrayBuffer}).promise;
        for(let i=1; i<=Math.min(pdf.numPages,5); i++){
          const page = await pdf.getPage(i);
          const textContent = await page.getTextContent();
          extractedText += textContent.items.map(item=>item.str).join(" ") + "\n";
        }
      } else {
        const result = await Tesseract.recognize(file, "ara+fra+eng", {logger:()=>{}});
        extractedText = result.data.text;
      }

      const text = extractedText;
      let firstName="", lastName="", phone="", ccp="", birthDate="";

      // ===== الاسم من بطاقة التعريف =====
      // بطاقة التعريف: "اللقب: KORICHI" و "الاسم: ROMAISSA"
      // أو: "Nom: KORICHI" و "Prénom: ROMAISSA"
      const laqabMatch = text.match(/(?:اللقب|Nom)[\s:،]+([A-Z][A-Z\s]{1,20}?)(?:\s{2,}|\n|الاسم|Pr)/);
      const ismMatch  = text.match(/(?:الاسم|Pr[eé]nom)[\s:،]+([A-Z][A-Z\s]{1,20}?)(?:\s{2,}|\n|تاريخ|Date)/);
      if(laqabMatch) lastName  = laqabMatch[1].trim();
      if(ismMatch)   firstName = ismMatch[1].trim();

      // fallback: KORICHI<<ROMAISSA pattern (MRZ)
      if(!lastName||!firstName){
        const mrzMatch = text.match(/([A-Z]{2,})<<([A-Z]{2,})/);
        if(mrzMatch){ lastName=mrzMatch[1]; firstName=mrzMatch[2]; }
      }

      // ===== تاريخ الميلاد =====
      // dd/mm/yyyy أو yyyy.mm.dd أو yyyy/mm/dd
      const datePatterns = [
        /(?:تاريخ الميلاد|Date de Naissance|Né le|n[eé])[\s:،]*(\d{2}[\/.\-]\d{2}[\/.\-]\d{4})/i,
        /(?:تاريخ الميلاد|Date de Naissance)[\s:،]*(\d{4}[\/.\-]\d{2}[\/.\-]\d{2})/i,
        /\b(\d{2}\/\d{2}\/\d{4})\b/,
        /\b(\d{4}\.\d{2}\.\d{2})\b/,
      ];
      for(const pat of datePatterns){
        const m = text.match(pat);
        if(m){ birthDate = m[1]; break; }
      }

      // ===== CCP من الصك =====
      // الصك: "0042387994  23" أو "0079999990042387994 23"
      const chequeCcpMatch = text.match(/00(\d{8})\s*(\d{2})/);
      if(chequeCcpMatch){
        ccp = chequeCcpMatch[1] + " / " + chequeCcpMatch[2];
      }
      // fallback: رقم 8 أرقام يبدأ بـ 4
      if(!ccp){
        const ccpSimple = text.match(/\b(4\d{7})\b/);
        if(ccpSimple) ccp = ccpSimple[1];
      }

      // ===== الهاتف =====
      const phoneMatch = text.match(/0[5-7]\d{8}/);
      if(phoneMatch) phone = phoneMatch[0];

      const clientName = [firstName, lastName].filter(Boolean).join(" ");

      setForm(f=>({
        ...f,
        client: clientName || f.client,
        phone: phone || f.phone,
        ccp: ccp || f.ccp,
      }));

      const info = [];
      if(clientName) info.push("الاسم: " + clientName);
      if(phone) info.push("الهاتف: " + phone);
      if(ccp) info.push("CCP: " + ccp);
      if(birthDate) info.push("تاريخ الميلاد: " + birthDate);

      if(info.length > 0){
        alert("✅ تم استخراج:\n" + info.join("\n"));
      } else {
        alert("⚠️ ما قدرش يستخرج معلومات\nتأكد أن الصورة واضحة");
      }

    }catch(err){
      console.error(err);
      alert("❌ خطأ: " + err.message);
    }
    setAiLoading(false);
  }

