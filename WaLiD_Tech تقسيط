  function importFromExcel(file){
    const reader=new FileReader();
    reader.onload=(e)=>{
      try{
        const wb=XLSX.read(new Uint8Array(e.target.result),{type:"array"});
        const ws=wb.Sheets[wb.SheetNames[0]];
        const rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:""});
        let firstName="",lastName="",phone="",product="",price="",downPayment="0",months=12,ccp="",cle="",startDate="",endDate="";

        // CCP / CLE
        try{ccp=String(rows[5]?.[2]||"").trim();cle=String(rows[5]?.[1]||"").trim();}catch(e){}

        // تاريخ أول قسط E11 (row10, col4) — البداية = أول قسط ناقص شهر
        try{
          // Try E11 first (row index 10), then E15 (row index 14)
          const sd = rows[10]?.[4] || rows[14]?.[4];
          if(sd){
            let d;
            if(typeof sd === "number"){
              d = new Date(Math.round((sd - 25569) * 86400 * 1000));
            } else if(sd instanceof Date){
              d = sd;
            } else {
              d = new Date(sd);
            }
            if(!isNaN(d.getTime()) && d.getFullYear() > 1970){
              // startDate = day 02 of the month before first installment
              const start = new Date(d);
              start.setMonth(start.getMonth()-1);
              start.setDate(2);
              startDate = start.toISOString().split("T")[0];
            }
          }
        }catch(e){}

        // تاريخ النهاية: آخر تاريخ في E15:E32 (rows 14-31, col4)
        try{
          let lastDate=null;
          for(let i=14;i<=31;i++){
            const v=rows[i]?.[4];
            if(v){
              let d;
              if(typeof v==="number"){d=new Date(Math.round((v-25569)*86400*1000));}
              else{d=new Date(v);}
              if(!isNaN(d.getTime())&&d.getFullYear()>1970) lastDate=d;
            }
          }
          if(lastDate) endDate=lastDate.toISOString().split("T")[0];
        }catch(e){}

        rows.forEach(row=>{
          row.forEach((cell,j)=>{
            const s=String(cell||"").trim();
            if(s.includes("الاسم")&&s.includes("FR")) firstName=String(row[j+1]||"").trim();
            if(s.includes("اللقب")&&s.includes("FR")) lastName=String(row[j+1]||"").trim();
            if(s.includes("ارق")&&s.includes("الهاتف")) phone=String(row[j+1]||"").trim();
            if(s.includes("اقضي بشراء")) product=String(row[j+1]||"").trim();
            if(s.includes("بمبلغ")||s.includes("بمـ")){
              let found=false;
              for(let k=j+1;k<row.length;k++){
                const n=Number(row[k]);
                if(!isNaN(n)&&row[k]!==""){
                  if(!found){price=String(Math.round(n));found=true;}
                  else{downPayment=String(Math.round(n));break;}
                }
              }
            }
            if(s.replace(/\u0640/g,"").includes("مقسط")){
              for(let k=j+1;k<row.length;k++){
                const n=Number(row[k]);
                if(!isNaN(n)&&n>0){months=Math.round(n);break;}
              }
            }
          });
        });

        // حساب الأشهر من التواريخ إذا متوفرة
        if(startDate&&endDate){
          const s=new Date(startDate),en=new Date(endDate);
          const diff=Math.round((en-s)/(1000*60*60*24*30));
          if(diff>0) months=diff;
        }

        const clientName=[firstName,lastName].filter(Boolean).join(" ");
        setForm(f=>({...f,
          client:clientName||f.client,
          phone:phone||f.phone,
          ccp:ccp&&cle?(ccp+" / "+cle):(ccp||f.ccp),
          product:product||f.product,
          price:price||f.price,
          downPayment,
          months:MONTHS_LIST.includes(months)?months:f.months,
          startDate:f.startDate,
        }));
      }catch(e){console.error(e);}
    };
    reader.readAsArrayBuffer(file);
  }

